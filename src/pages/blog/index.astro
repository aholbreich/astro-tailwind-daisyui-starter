---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Sectionhead from '@components/elements/Sectionhead.astro';

type Post = CollectionEntry<'blog'>;

// Fetch all non-draft posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a: Post, b: Post) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description="All posts">
  <Sectionhead>
    <Fragment slot="title">Blog</Fragment>
    <Fragment slot="desc">All posts, newest first.</Fragment>
  </Sectionhead>

  <section class="container mx-auto px-4 py-12 max-w-3xl">
    {posts.length === 0 && (
      <p class="text-base-content/60">No posts yet. Add a Markdown file to <code>src/content/blog/</code>.</p>
    )}

    <ul class="flex flex-col gap-6">
      {posts.map((post: Post) => (
        <li>
          <a href={`/blog/${post.id}`} class="card card-border bg-base-100 hover:shadow-md transition-shadow">
            <div class="card-body">
              <h2 class="card-title">{post.data.title}</h2>
              <p class="text-base-content/70 text-sm">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </p>
              <p>{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
