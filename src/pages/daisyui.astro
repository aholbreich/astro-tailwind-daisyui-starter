---
import Buttons from "@components/daisyui/Buttons.astro";
import Container from "@components/elements/Container.astro";
import Sectionhead from "@components/elements/Sectionhead.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="DaisyUI reference"
  description="Small DaisyUI reference page included with the starter."
>
  <Container class="py-12 sm:py-16 lg:py-24">
    <Sectionhead eyebrow="Reference">
      <Fragment slot="title">DaisyUI is the default UI layer.</Fragment>
      <Fragment slot="desc">
        This page is intentionally small. It shows that DaisyUI is wired up and ready to use without turning the starter into a component gallery.
      </Fragment>
    </Sectionhead>

    <div class="mt-10 max-w-3xl">
      <Buttons />
    </div>
  </Container>
</Layout>
