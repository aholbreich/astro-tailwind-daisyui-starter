---
import Buttons from "@components/daisyui/Buttons.astro";
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="DaisyUI reference"
  description="Small DaisyUI reference page included with the starter."
>
  <Container class="py-16">
    <div class="max-w-3xl space-y-4">
      <p class="badge badge-outline">Reference page</p>
      <h1 class="text-4xl font-bold tracking-tight">DaisyUI is the default UI layer.</h1>
      <p class="text-base-content/70 text-lg">
        This page is intentionally small. It exists to show that DaisyUI is wired up and ready to use, not to turn the starter into a component gallery.
      </p>
      <p class="text-base-content/70">
        Keep it as a quick reference, expand it for your own project, or delete it once you no longer need it.
      </p>
    </div>

    <div class="mt-10">
      <Buttons />
    </div>
  </Container>
</Layout>
