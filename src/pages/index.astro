---
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "site-config";

const quickstart = `pnpm create astro@latest --template ${siteConfig.githubRepo}`;

// Keep page content data-driven so the homepage stays easy to scan and edit.
const defaults = [
  "Astro 5 with Tailwind CSS 4 and DaisyUI 5",
  "Typed blog content collection with Markdown and MDX support",
  "SEO metadata, sitemap, robots.txt, and local SVG icons",
  "Dark mode toggle, skip link, and reduced-motion support",
];

const principles = [
  "DaisyUI is included on purpose as the default UI layer.",
  "Alpine is only used for tiny progressive enhancement needs.",
  "Examples are meant to be easy to delete, not hard to work around.",
  "Removal scripts exist as convenience escape hatches, not as the product story.",
];

const starterTraits = [
  "Opinionated enough to be useful",
  "Small enough to understand quickly",
  "Ready for production work with low setup friction",
  "Easy to customize without losing control",
];
---

<Layout
  title="Production-ready Astro starter"
  description="Production-ready Astro starter with Tailwind CSS 4, DaisyUI 5, blog support, SEO basics, and optional Alpine JS."
>
  <Container class="py-12 sm:py-16 lg:py-24">
    <!--
      Mobile-first structure:
      1. Start with a single-column stack that reads well on narrow screens.
      2. Introduce multi-column layouts only from `lg:` upward.
    -->
    <section class="space-y-8 lg:grid lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,24rem)] lg:gap-10 lg:space-y-0">
      <div class="space-y-6">
        <p class="badge badge-outline">Production-ready Astro starter</p>

        <div class="space-y-4">
          <h1 class="max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
            Astro, Tailwind, and DaisyUI with strong defaults and clear control.
          </h1>
          <p class="max-w-2xl text-base text-base-content/70 sm:text-lg">
            This starter is designed to help developers move quickly without inheriting a theme, a setup wizard, or a pile of abstractions that are hard to remove later.
          </p>
          <p class="max-w-2xl text-base text-base-content/70 sm:text-lg">
            It is opinionated enough to be useful, small enough to understand quickly, and structured to stay friendly to both experienced Astro users and newcomers.
          </p>
        </div>

        <!-- Full-width buttons on mobile are easier to tap and scan. -->
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="btn btn-primary w-full sm:w-auto" href="/blog">View blog example</a>
          <a class="btn btn-outline w-full sm:w-auto" href="/daisyui">View DaisyUI reference</a>
        </div>

        <ul class="grid gap-3 sm:grid-cols-2">
          {starterTraits.map((trait) => (
            <li class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75 shadow-sm">
              {trait}
            </li>
          ))}
        </ul>
      </div>

      <aside class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <p class="text-sm font-semibold uppercase tracking-wide text-base-content/60">Quick start</p>
          <pre class="overflow-x-auto rounded-box bg-base-200 p-4 text-sm"><code>{quickstart}</code></pre>
          <p class="text-sm text-base-content/70">
            Update `src/site-config.ts`, replace the sample content, and delete anything you do not need.
          </p>
          <div class="divider my-0"></div>
          <p class="text-sm text-base-content/70">
            The starter ships with the Netlify adapter by default, but the project stays easy to retarget.
          </p>
        </div>
      </aside>
    </section>

    <!-- Secondary information stays below the hero on mobile, then becomes a two-column grid. -->
    <section class="mt-10 grid gap-6 lg:mt-14 lg:grid-cols-2">
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Included by default</h2>
          <ul class="space-y-3 text-sm text-base-content/75 sm:text-base">
            {defaults.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-primary"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Starter principles</h2>
          <ul class="space-y-3 text-sm text-base-content/75 sm:text-base">
            {principles.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-secondary"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </Container>
</Layout>
